POSTGRES_DB=price_compare
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/price_compare

STEAM_REQUEST_DELAY=4.0
DMARKET_REQUEST_DELAY=1.0

# DMarket Trading API keys (dmarket.com -> Settings -> Trading API).
# Required to parse DMarket: its public market API now needs signed requests.
# Public key: 64 hex chars. Secret key: 128 hex chars. No 0x prefix.
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=

# Proxy pool (optional). Auto-enabled when the list file exists.
# PROXY_LIST_FILE=proxy_list.txt
# PROXY_COOLDOWN=60.0
# PROXY_ENABLED=true
# Longer cooldown for proxies that hit Steam's 429 (Steam bans IPs for hours).
# STEAM_PROXY_COOLDOWN=1800.0